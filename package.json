{
    "name": "eslint-config-jwalker",
    "version": "12.2.0",
    "description": "Shareable framework-agnostic ESLint config",
    "author": "Jonatas Walker",
    "homepage": "https://github.com/jonataswalker/eslint-config-jwalker",
    "type": "module",
    "engines": {
        "node": "^22.20 || ^24"
    },
    "exports": {
        "./package.json": "./package.json",
        ".": "./config/index.js"
    },
    "types": "./config/index.d.ts",
    "files": [
        "config"
    ],
    "keywords": [
        "eslint-config"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jonataswalker/eslint-config-jwalker.git"
    },
    "bugs": {
        "url": "https://github.com/jonataswalker/eslint-config-jwalker/issues"
    },
    "license": "MIT",
    "scripts": {
        "prelint": "npm run knip",
        "lint": "eslint .",
        "lint:fix": "npm run lint -- --fix",
        "config": "eslint --print-config index.js",
        "view:config": "npx @eslint/config-inspector",
        "gen:types": "tsc",
        "prepare": "husky",
        "knip": "knip",
        "test": "node --test **/*.spec.js",
        "release": "release-it --no-npm.publish"
    },
    "dependencies": {
        "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "@typescript-eslint/utils": "^8.61.1",
        "eslint": "^10.5.0",
        "eslint-config-flat-gitignore": "^2.3.0",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-array-func": "^5.1.1",
        "eslint-plugin-es-x": "^9.6.0",
        "eslint-plugin-format": "^2.0.1",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-jsonc": "^3.2.0",
        "eslint-plugin-n": "^18.1.0",
        "eslint-plugin-perfectionist": "^5.9.1",
        "eslint-plugin-promise": "^7.3.0",
        "eslint-plugin-security": "^4.0.1",
        "eslint-plugin-unicorn": "^67.0.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.6.0",
        "jsonc-eslint-parser": "^3.1.0",
        "typescript-eslint": "^8.61.1"
    },
    "devDependencies": {
        "@eslint/config-inspector": "^3.0.4",
        "@types/node": "^25.9.3",
        "husky": "^9.1.7",
        "knip": "^6.17.1",
        "release-it": "^20.2.0",
        "typescript": "^6.0.3"
    },
    "release-it": {
        "github": {
            "release": true
        }
    }
}
